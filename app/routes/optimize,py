from fastapi import APIRouter

router = APIRouter()


@router.post("/optimize")
async def optimize(data: dict):

    content = data.get("content", "")

    facebook_post = (
        f"{content}\n\n"
        "#ScanForSafe #VehicleSafety #EmergencyHelp"
    )

    instagram_post = (
        f"{content}\n\n"
        "🚨 Stay safe everywhere.\n\n"
        "#ScanForSafe #Emergency #Safety "
        "#RoadSafety #QRCode #VehicleSafety"
    )

    twitter_post = (
        f"{content[:180]} #ScanForSafe"
    )

    linkedin_post = (
        f"{content}\n\n"
        "ScanForSafe helps improve emergency response "
        "and vehicle safety using smart QR technology."
    )

    whatsapp_post = (
        f"{content}\n\n"
        "Stay safe. Share with family and friends."
    )

    youtube_post = (
        f"{content}\n\n"
        "Subscribe for more safety awareness updates."
    )

    return {
        "success": True,
        "data": {
            "original": content,
            "facebook": facebook_post,
            "instagram": instagram_post,
            "twitter": twitter_post,
            "linkedin": linkedin_post,
            "whatsapp": whatsapp_post,
            "youtube": youtube_post
        }
    }